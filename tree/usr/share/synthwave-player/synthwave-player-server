# WebSocket for real-time notifications
# Note: In multi-worker mode, each worker maintains its own WebSocket connections.
websocket '/api/ws' => sub ($c) {
    $c->inactivity_timeout(3600);

    my $db = $c->app->db;
    my $address = $c->remote_address_with_port;
    my $worker_id = $$; # Process ID for debugging
    $c->app->log->debug("WebSocket client connected from $address (worker: $worker_id)");
    $db->{websockets}{$c->tx} = $c;

    # Send current source hash to client immediately so it can detect if it needs to reload
    $c->send({json => {
        event       => 'version',
        source_hash => $SOURCE_HASH,
        version     => $APP_VERSION
    }});

    # Send a ping and version every 15 seconds to keep the connection alive and detect updates
    my $ping_timer = Mojo::IOLoop->singleton->recurring(15 => sub {
        try {
            # Cleanup stale websocket references from the global hash
            # This prevents memory leaks if the 'finish' event fails to fire
            for my $tx (keys %{$db->{websockets}}) {
                delete $db->{websockets}{$tx} if !$tx || $tx->is_finished;
            }

            $c->send({json => { event => 'ping' }});
            $c->send({json => {
                event       => 'version',
                source_hash => $SOURCE_HASH,
                version     => $APP_VERSION
            }});
        } catch {};
    });

    $c->on(finish => sub {
        Mojo::IOLoop->singleton->remove($ping_timer) if $ping_timer;
        delete $db->{websockets}{$c->tx};
        remove_from_ip_cache($address) if $address;
        $c->app->log->debug("WebSocket client from $address disconnected (worker: $worker_id)");
    });
};

# API: GET /api/config - Returns user configuration details
get '/api/config' => sub ($c) {
    my $address = $c->remote_address_with_port;
    my $is_private = is_private_ip($address, \@PRIVATE_NETWORKS, $c->app->log);
    my $is_admin = $c->is_admin;

    unless ($is_admin || ($is_private && $ALLOW_LOCAL_NETWORK_EDITING && $ADMIN_PASSWORD)) {
        return $c->render(text => 'Forbidden', status => 403);
    }

    # Always re-read configuration file to allow manual modifications
    _load_configuration($c->app);

    my $current_config = _get_config_values_for_client();

    $c->render(json => {
        settings => \%CONFIG_VARS,
        values   => $current_config,
        path     => $USER_CONFIG_FILE,
        default_music_dir => _get_xdg_dir('MUSIC')
    });
};

# API: POST /api/config - Saves user configuration
post '/api/config' => sub ($c) {
    my $address = $c->remote_address_with_port;
    my $is_private = is_private_ip($address, \@PRIVATE_NETWORKS, $c->app->log);
    my $is_admin = $c->is_admin;

    unless ($is_admin || ($is_private && $ALLOW_LOCAL_NETWORK_EDITING && $ADMIN_PASSWORD)) {
        return $c->render(text => 'Forbidden', status => 403);
    }

    my $new_values = $c->req->json;

    # 0. Keep track of old directories to detect removals
    my @old_dirs = @SynthwavePlayer::Config::MUSIC_DIRECTORIES;
    my @old_friends = @SynthwavePlayer::Config::FRIENDS_MUSIC;

    # 1. Update and save configuration
    try {
        my $current_config = _update_config($c->app, $new_values);
        # Sync library state immediately
        $c->app->sync_library_to_config(\@old_dirs, $current_config->{MUSIC_DIRECTORIES}, \@old_friends, $current_config->{FRIENDS_MUSIC});

        # Update the stored hash so the watcher/dispatch doesn't trigger it again
        my $new_hash = $c->get_config_hash;
        $c->app->sql->db->query("INSERT OR REPLACE INTO scan_state (key, value) VALUES ('config_hash', ?)", $new_hash);
    } catch {
        return $c->render(json => { success => 0, message => "Failed to save configuration: $_" }, status => 500);
    };

    # The file watcher will also pick up the change as a safety net.
    $c->render(json => { success => 1, message => "Configuration saved. The page will now reload." });
};

# API: POST /api/admin/set-password - Sets the initial admin password
post '/api/admin/set-password' => sub ($c) {
    my $address = $c->remote_address_with_port;
    unless ($ALLOW_ADMIN_FROM_ANY_NETWORK || is_private_ip($address, \@PRIVATE_NETWORKS, $c->app->log)) {
        return $c->render(text => 'Forbidden', status => 403);
    }

    # Ensure we have the latest config before checking if password is set
    _load_configuration($c->app) if !$SynthwavePlayer::Config::ADMIN_PASSWORD || $SynthwavePlayer::Config::ADMIN_PASSWORD eq '';

    # This endpoint is only for setting the initial password
    return $c->render(json => { success => 0, message => 'Password is already set.' }) if $SynthwavePlayer::Config::ADMIN_PASSWORD && $SynthwavePlayer::Config::ADMIN_PASSWORD ne '';

    my $params = $c->req->json;
    my $pass = $params->{password};

    unless ($pass && length($pass) >= 4) { # Basic validation
        return $c->render(json => { success => 0, message => 'Password must be at least 4 characters.' });
    }

    # Update and save configuration
    try {
        # Set a flag to prevent the file watcher from triggering a global reload
        # since we are handling the state change locally in the frontend.
        $c->app->db->{suppress_config_broadcast} = 1;
        _update_config($c->app, { ADMIN_PASSWORD => $pass });
        # Keep the suppression active long enough for the watcher's 2s timer to fire
        Mojo::IOLoop->singleton->timer(5 => sub { delete $c->app->db->{suppress_config_broadcast} });
    } catch {
        return $c->render(json => { success => 0, message => "Failed to write to config file: $_" }, status => 500);
    };

    return $c->render(json => { success => 1, message => 'Admin password set successfully.' });
};

# API: POST /api/admin/login - Authenticates a user for admin mode
post '/api/admin/login' => sub ($c) {
    my $ip = $c->tx->remote_address;
    my $address = $c->remote_address_with_port;
    unless ($ALLOW_ADMIN_FROM_ANY_NETWORK || is_private_ip($address, \@PRIVATE_NETWORKS, $c->app->log)) {
        return $c->render(text => 'Forbidden', status => 403);
    }

    # Ensure we have the latest config before checking if password is set
    _load_configuration($c->app) if !$SynthwavePlayer::Config::ADMIN_PASSWORD || $SynthwavePlayer::Config::ADMIN_PASSWORD eq '';

    unless ($SynthwavePlayer::Config::ADMIN_PASSWORD && $SynthwavePlayer::Config::ADMIN_PASSWORD ne '') {
        return $c->render(json => { success => 0, message => 'Admin password is not set.' });
    }

    # Check for active lockout
    if (my $lockout_until = get_login_lockout($ip)) {
        return $c->render(json => {
            success => 0,
            message => 'Too many failed attempts. Access restricted.',
            lockout_until => $lockout_until
        });
    }

    # Tell Mojolicious we will render later
    $c->render_later;

    # Pause to slow down brute-force attacks. This happens on every attempt.
    Mojo::IOLoop->singleton->timer(2 => sub {
        my $params = $c->req->json;
        my $hashed_input = $params->{password} // '';

        my ($success, $message, $lockout_until) = process_login($c, $hashed_input, $SynthwavePlayer::Config::ADMIN_PASSWORD);

        $c->render(json => {
            success => $success,
            message => $message,
            is_admin => $success,
            lockout_until => $lockout_until
        });
    });
};

