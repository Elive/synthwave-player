# API: GET /api/cover_exists/:id - Checks if cover art exists for a song
get '/api/cover_exists/:id' => sub ($c) {
    return unless _apply_rate_limit($c);

    my $partial_id = $c->param('id');

    # Validate that ID is a hex hash
    unless ($partial_id && $partial_id =~ /^[0-9a-f]{1,16}$/i) {
        return $c->render(json => { exists => 0 });
    }

    my ($song_arr, $full_id) = _find_song_by_partial_id($c, $partial_id);
    unless ($song_arr) {
        return $c->render(json => { exists => 0 });
    }

    my $cover_info = _get_cover_art_data($c, $full_id);

    if ($cover_info) {
        return $c->render(json => { exists => 1 });
    } else {
        return $c->render(json => { exists => 0 });
    }
};

