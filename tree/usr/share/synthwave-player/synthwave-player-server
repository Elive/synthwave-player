helper rate_limiter => sub {
    my $c = shift;
    my $config = {
        private_networks            => \@PRIVATE_NETWORKS,
        rate_limit_window           => $RATE_LIMIT_WINDOW,
        global_rate_limit_window    => $GLOBAL_RATE_LIMIT_WINDOW,
