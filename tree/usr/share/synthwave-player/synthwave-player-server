# API: GET /api/check_update - Checks for new versions on GitHub
get '/api/check_update' => sub ($c) {
    my $address = $c->remote_address_with_port;
    my $is_private = is_private_ip($address, \@PRIVATE_NETWORKS, $c->app->log);
    my $is_admin = $c->is_admin;

    unless ($is_admin || ($is_private && $ALLOW_LOCAL_NETWORK_EDITING && $ADMIN_PASSWORD)) {
        return $c->render(text => 'Forbidden', status => 403);
    }

    my $info = _get_update_info($c->app);
    if ($info->{error}) {
        return $c->render(json => { error => $info->{error} }, status => 500);
    }
    # The URL for "Install update" button should be the release page not the download URL
    $info->{url} = "https://github.com/Elive/synthwave-player/releases/latest";
    $info->{patreon_url} = "https://www.patreon.com/c/elive";
    return $c->render(json => $info);
};

# GET / - The main application page
get '/' => sub {
    my $c = shift;
    my $ip = $c->tx->remote_address;
    my $address = $c->remote_address_with_port;
    my $is_private_network = is_private_ip($address, \@PRIVATE_NETWORKS, $c->app->log);
    if ($ENABLE_DEBUG_LOGGING) {
        my $network_location = $is_private_network ? 'local network' : 'remote';
        my $ua = $c->req->headers->user_agent // 'Unknown';
        # $c->app->log->debug('');
        # $c->app->log->debug('------------------------------------------------------------');
        $c->app->log->debug("--- New client connected from $ip ($network_location) ---");
        $c->app->log->debug("User-Agent: $ua");
        # $c->app->log->debug('------------------------------------------------------------');
    }
    my $website_domain = $c->req->headers->host || $c->req->url->host || 'localhost';
    $website_domain =~ s/:\d+$//;

    # --- OG Tags for Song Sharing ---
    my $og_data = {};
    if (my $partial_id = $c->param('song')) {
        if ($partial_id =~ /^[0-9a-f]{1,16}$/i) {
            my ($song, $full_id) = _find_song_by_partial_id($c, $partial_id);
            if ($song) {
                my $protocol = $c->req->url->scheme;
                my $host = $c->req->headers->host || $c->req->url->host || "localhost:$APP_PORT";
                my $song_url = Mojo::URL->new->scheme($protocol)->host($host)->path('/')->query({ song => $full_id });

                $og_data = {
                    title       => $song->{title},
                    description => "Listen to " . $song->{title} . " by " . $song->{artist},
                    image       => Mojo::URL->new->scheme($protocol)->host($host)->path("/cover/$full_id")->to_string,
                    url         => $song_url->to_string,
                };
            }
        }
    }

    # --- Content Security Policy ---
    my @csp_directives;

    if ($ENABLE_RADIO_STATIONS_HTTP) {
        push @csp_directives, "media-src 'self' http: https: blob:";
    }

    if (@csp_directives) {
        $c->res->headers->header('Content-Security-Policy', join('; ', @csp_directives));
    }

    $c->render(
        'index_synthwave',
        og_data                       => $og_data,
        ui_font_size_desktop          => $UI_FONT_SIZE_DESKTOP,
        ui_font_size_mobile           => $UI_FONT_SIZE_MOBILE,
        ui_font_family                => $UI_FONT_FAMILY,
        lyrics_font_size_desktop      => $LYRICS_FONT_SIZE_DESKTOP,
        lyrics_font_size_mobile       => $LYRICS_FONT_SIZE_MOBILE,
        lyrics_font_family            => $LYRICS_FONT_FAMILY,
        welcome_message               => $WELCOME_MESSAGE,
        enable_cover_art              => $ENABLE_COVER_ART ? 1 : 0,
        enable_online_lyrics_search   => $ENABLE_ONLINE_LYRICS_SEARCH ? 1 : 0,
        website_title                 => $WEBSITE_TITLE,
        website_domain                => $website_domain,
        protocol                      => $c->req->url->scheme,
        is_private_network            => $is_private_network ? 1 : 0,
        is_admin                      => $c->is_admin ? 1 : 0,
        default_sort_by               => $DEFAULT_SORT_BY,
        default_sort_order            => $DEFAULT_SORT_ORDER,
        scroll_to_song_align_mobile   => $SCROLL_TO_SONG_ALIGN_MOBILE,
        scroll_to_song_align_desktop  => $SCROLL_TO_SONG_ALIGN_DESKTOP,
        songs_per_page                => $SONGS_PER_PAGE,
        min_search_length             => $MIN_SEARCH_LENGTH,
        previous_button_restart_seconds => $PREVIOUS_BUTTON_RESTART_SECONDS,
        ignore_playback_errors_ms     => $IGNORE_PLAYBACK_ERRORS_MS,
        notification_visible_ms       => $NOTIFICATION_VISIBLE_MS,
        sidebar_auto_collapse_delay_ms => $SIDEBAR_AUTO_COLLAPSE_DELAY_MS,
        initial_songs_to_load_mobile  => $INITIAL_SONGS_TO_LOAD_MOBILE,
        initial_songs_to_load_desktop => $INITIAL_SONGS_TO_LOAD_DESKTOP,
        songs_to_load_on_scroll_mobile => $SONGS_TO_LOAD_ON_SCROLL_MOBILE,
        songs_to_load_on_scroll_desktop => $SONGS_TO_LOAD_ON_SCROLL_DESKTOP,
        show_playback_speed_min_minutes => $SHOW_PLAYBACK_SPEED_MIN_MINUTES,
