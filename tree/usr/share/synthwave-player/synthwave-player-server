helper sql => sub {
    state $db_path = File::Spec->catfile(_get_cache_dir(), 'library.db');
    state $sql;

    # Detect if database file was deleted while server is running
    # Note: force_db_reconnect is per-process, set by _setup_database_watcher
    if ($sql && (!-f $db_path || app->db->{force_db_reconnect})) {
        app->log->warn("Database file '$db_path' was deleted or reconnection forced. Re-initializing...");
        $sql = undef;
        app->db->{new_db_notification} = 1;
        delete app->db->{force_db_reconnect};
    }

    # Always check if DB file exists before creating connection
    if (!$sql && !-f $db_path) {
        app->log->info("Database file not found, will be created at: $db_path");
    }

    return $sql if $sql;

    $sql = do {
        my $s = Mojo::SQLite->new("sqlite:$db_path");
        init_sql_handle($s);

        # Initialize database schema if needed (only once per process)
        try {
            init_database($s->db);
        } catch {
            # If it fails here, it's likely because another worker is already initializing it.
            # We log it as a warning instead of a fatal error.
            app->log->warn("Database initialization notice (might be locked by another worker): $_");
        };

        $s;
    };

    return $sql;
};

helper db => sub {
    state $db = {
        loading_status => { done => 0, total => 0, processed => 0, message => 'Initializing...', progress => 0 },
        playlists_out_of_date => {},
        websockets => {}
