# This hook runs once in each worker process after it's been forked.
# Note: In multi-worker mode, each worker runs this independently.
# The sync_library_to_config helper handles its own locking to prevent races.
hook startup => sub {
    my $app = shift;
    _load_configuration($app);
    $app->secrets([$SynthwavePlayer::Config::ADMIN_PASSWORD || 'synthwave-player-default-secret']);

    # Check for configuration changes while offline or if DB was recreated.
    # Use a small random delay to stagger workers and reduce DB contention
    my $delay = int(rand(2)) + 1;
    Mojo::IOLoop->singleton->timer($delay => sub {
        my $current_hash = $app->get_config_hash;

        try {
            my $db = $app->sql->db;
            my $stored_hash_row = $db->query("SELECT value FROM scan_state WHERE key = 'config_hash'")->array;
            my $stored_hash = $stored_hash_row ? ($stored_hash_row->[0] // '') : '';

            if ($current_hash ne $stored_hash) {
                my $is_new_db = !$stored_hash;
                $app->log->info($is_new_db ? "New database detected. Initializing library..." : "Configuration change detected offline. Synchronizing...");

                if ($is_new_db) {
                    $app->db->{new_db_notification} = 1;
                }

                # Trigger synchronization. We use the app helper.
                # We pass empty arrays for 'old' as the helper now queries the DB for removals.
                # The helper handles its own locking to prevent multi-worker races.
                if ($app->sync_library_to_config([], \@SynthwavePlayer::Config::MUSIC_DIRECTORIES, [], \@SynthwavePlayer::Config::FRIENDS_MUSIC)) {
                    $db->query("INSERT OR REPLACE INTO scan_state (key, value) VALUES ('config_hash', ?)", $current_hash);
                }
            }
        } catch {
            if ($_ =~ /rollback ineffective/i || $_ =~ /database is locked/i) {
                $app->log->debug("Database busy during startup config check, will retry on next dispatch.");
            } else {
                $app->log->error("Database error during startup config check: $_");
            }
        };
    });
};

# Trust X-Forwarded-For header from our Nginx proxy.
hook before_dispatch => sub {
    my $c = shift;
    if (my $proto = $c->req->headers->header('X-Forwarded-Proto')) {
        $c->req->url->scheme($proto);
    }
    if (my $forwarded_for = $c->req->headers->header('X-Forwarded-For')) {
        my @ips = split /\s*,\s*/, $forwarded_for;
        $c->tx->remote_address($ips[0]) if @ips;
    }

    # Ensure config is fresh. This handles synchronization between worker processes.
    # _load_configuration now checks mtime internally for efficiency.
    _load_configuration($c->app);


    # Check if music directories changed (e.g. manual config file edit)
    state $last_seen_hash;
    my $current_hash = $c->get_config_hash;

    if (!$last_seen_hash || $current_hash ne $last_seen_hash) {
        try {
            my $db = $c->app->sql->db;
            my $stored_hash_row = $db->query("SELECT value FROM scan_state WHERE key = 'config_hash'")->array;
            my $stored_hash = $stored_hash_row ? ($stored_hash_row->[0] // '') : '';

            if ($current_hash ne $stored_hash) {
                # Attempt synchronization. The helper handles its own locking/concurrency logic.
                $c->app->log->info("Configuration change detected. Synchronizing...");

                # Get old directories from DB to compare
                my $old_dirs = $db->query("SELECT path FROM configured_directories")->arrays->map(sub { $_->[0] })->to_array;

                if ($c->sync_library_to_config($old_dirs, \@SynthwavePlayer::Config::MUSIC_DIRECTORIES, [], \@SynthwavePlayer::Config::FRIENDS_MUSIC)) {
                    $db->query("INSERT OR REPLACE INTO scan_state (key, value) VALUES ('config_hash', ?)", $current_hash);
                }
                # Update local state regardless of whether this specific worker got the lock.
                # This prevents other workers from spamming "Another worker is scanning".
                $last_seen_hash = $current_hash;
            } else {
                $last_seen_hash = $current_hash;
            }
        } catch {
            # Ignore DB busy errors here, it will be retried on next dispatch
            if ($_ !~ /rollback ineffective/i && $_ !~ /database is locked/i) {
                $c->app->log->error("Database error during dispatch config check: $_");
            }
        };
    }

    # Sync in-memory loading state with DB for multi-worker consistency
    $c->sync_loading_state_from_db();

    # Periodically suggest SQLite to release memory if idle
    state $last_shrink = time();
    if (time() - $last_shrink > 300) {
        try { $c->app->sql->db->query('PRAGMA shrink_memory') };
        $last_shrink = time();
    }

    # Check if playlists were marked out of date by another worker
    try {
        my $ood = $c->app->sql->db->query("SELECT value FROM scan_state WHERE key = 'playlists_out_of_date'")->array;
        if ($ood && $ood->[0]) {
            $c->app->db->{playlists_out_of_date}->{_global_} = 1;
        }
    } catch {};

    # Show notification if database was recreated
    if ($c->app->db->{new_db_notification}) {
        _stash_notification($c, 'database_recreated', "The music database was missing or deleted. It has been recreated and a full scan is starting.");
        delete $c->app->db->{new_db_notification};
    }
};

# Determine PID file path for Hypnotoad
my $pid_file;
my $uid = $>;
my $run_dir = "/run/user/$uid";
if (-d $run_dir && -w $run_dir) {
    $pid_file = "$run_dir/synthwave-player-server.pid";
} else {
    # Use a predictable but user-specific filename in /tmp
    my $user = getpwuid($uid) || $uid;
    $pid_file = "/tmp/.synthwave-player-server-$user.pid";
}

my $pid_avahi_file = $pid_file;
$pid_avahi_file =~ s/\.pid$/_avahi.pid/;

# Save PID for non-hypnotoad environments (morbo, perl, etc.)
# We delay this slightly to avoid interfering with hypnotoad's startup checks
Mojo::IOLoop->next_tick(sub {
    if (!$ENV{HYPNOTOAD_PID} && !$ENV{HYPNOTOAD_APP}) {
        if (open my $fh, '>', $pid_file) {
            print $fh $$;
            close $fh;
        }
    }
});

# Handle termination signals to ensure cleanup
my $cleanup_done = 0;
my $cleanup_routine = sub {
    return if $cleanup_done++;
    if (defined $pid_file && -f $pid_file) {
        # Only remove if it's our own PID file (not overwritten by another process)
        if (open my $fh, '<', $pid_file) {
            my $stored_pid = <$fh>;
            close $fh;
            if ($stored_pid && $stored_pid == $$) {
                unlink $pid_file;

                # Also cleanup Avahi process if we are the primary process exiting
                if (defined $pid_avahi_file && -f $pid_avahi_file) {
                    if (open my $afh, '<', $pid_avahi_file) {
                        my $avahi_pid = <$afh>;
                        close $afh;
                        if ($avahi_pid && $avahi_pid =~ /^\d+$/) {
                            kill('TERM', $avahi_pid) || kill('KILL', $avahi_pid);
                        }
                        unlink $pid_avahi_file;
                    }
                }
            }
        }
    }
    exit 0 if $_[0]; # Exit if called from signal
};

$SIG{TERM} = $SIG{INT} = sub { $cleanup_routine->(1) };

# Ensure PID file is removed on exit (global cleanup)
END {
    $cleanup_routine->();
}

