};

# GET /audio/:id - Streams the audio file for a given song ID
get '/audio/:id' => sub ($c) {
    return unless _apply_rate_limit($c);

    my $partial_id = $c->param('id');

    # Validate that ID is a hex hash
    unless ($partial_id && $partial_id =~ /^[0-9a-f]{1,16}$/i) {
        $c->app->log->error("Invalid song ID format: '$partial_id'");
        return $c->reply->not_found;
    }

    my ($song, $full_id) = _find_song_by_partial_id($c, $partial_id);
    return $c->reply->not_found unless $song;

    # Radio streams are now handled client-side.
    if ($song->{location} =~ /^https?:\/\//i) {
        $c->app->log->warn("Request for radio stream URL received on server, which should be handled client-side. ID: $full_id");
        return $c->reply->not_found;
    }

    # For local files, validate path and stream
    my $safe_path = _get_safe_song_path($c, $full_id);
    unless ($safe_path) {
        if (my $msg = $c->stash('error_notification')) {
            $c->res->headers->header('X-Error-Notification', uri_escape($msg));
        }
        return $c->reply->not_found;
    }

    if ($c->param('download')) {
        my $temp_dir = File::Spec->catdir(_get_cache_dir(), 'downloads');
        mkdir $temp_dir unless -d $temp_dir;

        # Cleanup old downloads (older than 1 hour)
        if (opendir(my $dh, $temp_dir)) {
            while (my $file = readdir($dh)) {
                next if $file =~ /^\./;
                my $path = File::Spec->catfile($temp_dir, $file);
                unlink $path if (stat($path))[9] < time - 3600;
            }
            closedir($dh);
        }

        my ($fh, $temp_file) = tempfile(DIR => $temp_dir, SUFFIX => '.mp3');
        close $fh;

        require File::Copy;
        if (File::Copy::copy($safe_path, $temp_file)) {
                my $covers_dir = $base_path->child('covers')->to_string;
                if (-d $covers_dir) {
                    if (opendir(my $cdh, $covers_dir)) {
                        my @covers = grep { /\.(jpg|jpeg|png)$/i } readdir($cdh);
                        closedir($cdh);

                        if (@covers) {
                            my $random_cover = File::Spec->catfile($covers_dir, $covers[rand @covers]);
                            # Use eyeD3 to inject the random cover
                            system("eyeD3", "--quiet", "--no-color", "--add-image", "$random_cover:FRONT_COVER", $temp_file, "1>/dev/null 2>&1");
                    }
                }
            }
            $c->res->headers->content_type('audio/mpeg');
            return $c->reply->file($temp_file);
        }
    }

    if ($ENABLE_VERBOSE_LOGGING) {
        my $ip = $c->tx->remote_address;
        $c->app->log->info(" -> Streaming song: \"$song->{title}\" by \"$song->{artist}\" to $ip");
    }

    # Explicitly create a file asset for streaming.
    # Mojolicious will automatically handle Range requests for seeking.
    $c->res->headers->content_type('audio/mpeg'); # Default to mpeg, browser will correct if needed
    my $asset = Mojo::Asset::File->new(path => $safe_path);
    $c->reply->asset($asset);
};

# GET /cover/:id - Extracts and streams the cover art for a given song ID using MP3::Tag
get '/cover/:id' => sub ($c) {
    return unless _apply_rate_limit($c);

    my $partial_id = $c->param('id');

    # Validate that ID is a hex hash
    unless ($partial_id && $partial_id =~ /^[0-9a-f]{1,16}$/i) {
        $c->app->log->error("Invalid cover art ID format: '$partial_id'");
        return $c->reply->not_found;
    }

    my ($song, $full_id) = _find_song_by_partial_id($c, $partial_id);
    return $c->reply->not_found unless $song;

    my $cover_info = _get_cover_art_data($c, $full_id);

    if ($cover_info) {
        my $format = $cover_info->{mime_type};
        $format =~ s/image\///;
        return $c->render(data => $cover_info->{data}, format => $format);
    } else {
        return $c->reply->not_found;
    }
};


